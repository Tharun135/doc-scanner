# .env.example for FastAPI App
# Copy this file to .env and configure your settings

# API Settings
APP_NAME=Doc Scanner RAG API
APP_VERSION=1.0.0
DEBUG=False
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# File Upload
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./uploads

# Vector Database
VECTOR_DB_DIR=./chroma_db
VECTOR_COLLECTION_NAME=doc_chunks
CHROMA_PERSIST=true

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
CHUNK_SIZE=300
CHUNK_OVERLAP=50

# Ollama (if using local LLM)
USE_OLLAMA=false
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM API Keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_API_URL=
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7

# Search
DEFAULT_TOP_K=5
MAX_TOP_K=20
SIMILARITY_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
LOG_FILE=

# CORS
CORS_ORIGINS=["*"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]
